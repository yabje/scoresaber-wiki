{
  "name": "@scoresaber/wiki",
  "version": "2.0.0",
  "description": "ScoreSaber Wiki",
  "license": "MIT",
  "author": "Umbranox <umbra@scoresaber.com>",
  "scripts": {
    "lint:md": "markdownlint content/docs/",
    "lint:md:fix": "markdownlint --fix content/docs/",
    "dev": "bun run i18n:generate && next dev",
    "build": "bun run i18n:generate && fumadocs-mdx && _FUMADOCS_MDX=1 next build && bun run build:aliases",
    "start": "serve out",
    "typecheck": "bun run i18n:generate && fumadocs-mdx && _FUMADOCS_MDX=1 next typegen && tsc --noEmit",
    "postinstall": "bun run i18n:generate && fumadocs-mdx",
    "lint": "oxlint src scripts source.config.ts next.config.mjs postcss.config.mjs",
    "build:aliases": "bun scripts/create-static-aliases.ts",
    "i18n:generate": "bun scripts/generate-active-locales.ts",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "prepare": "husky"
  },
  "dependencies": {
    "@orama/orama": "^3.1.18",
    "fumadocs-core": "^16.9.0",
    "fumadocs-mdx": "^15.0.7",
    "fumadocs-ui": "^16.9.0",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "remark-directive": "^4.0.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/bun": "^1.3.14",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "markdownlint-cli": "^0.48.0",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "postcss": "^8.5.15",
    "serve": "^14.2.6",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": ">=1.3.13 <2",
    "node": ">=24.15.0 <25"
  },
  "packageManager": "bun@1.3.13",
  "trustedDependencies": [
    "unrs-resolver"
  ]
}
